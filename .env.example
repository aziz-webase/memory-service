# Copy to .env. docker-compose reads this; the eval will drop their own values in.
# DB_URL is NOT here — it's pinned to the compose 'db' service in docker-compose.yml.

# pgvector collection name
COLLECTION_NAME=memory_collection

# Optional bearer token. Empty = auth disabled (service ignores the header).
MEMORY_AUTH_TOKEN=

# LLM for extraction/recall — OpenAI. The eval provides the key at run time.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# Override only to use an OpenAI-compatible endpoint (Azure, local vLLM, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1
